# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Build output ──────────────────────────────────────────────────────────────
proxiq
packages/*/dist/
packages/cli/.*.bun-build

# ── Runtime files ─────────────────────────────────────────────────────────────
*.pid
proxiq.pid

# ── Config — contains secrets (use *.example files as templates) ──────────────
.proxiq.json
claude-mcp.json
.env
.env.local
.env.*.local

# ── Proxiq data & cache ───────────────────────────────────────────────────────
.proxiq/

# ── Jekyll / GitHub Pages site ────────────────────────────────────────────────
site/_site/
site/cache/
site/gems/
site/specifications/
site/extensions/
site/.jekyll-cache/
site/.jekyll-metadata
# Ruby binstubs (generated by `bundle install --binstubs`) — not needed in git
site/bin/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor / local tooling ────────────────────────────────────────────────────
.vscode/
.idea/
.claude/
*.swp
*.swo
*.un~

# ── Test output ───────────────────────────────────────────────────────────────
coverage/

# ── Credentials / secrets (never commit these) ────────────────────────────────
ms-test-tenant.txt
*.pem
*.key
*.p12
*.pfx
secrets.json
